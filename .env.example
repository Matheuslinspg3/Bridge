PORT=8787
UPSTREAM_BASE_URL=https://api.nuoda.vip
UPSTREAM_API_KEY=SUA_CHAVE_NUODA_AQUI
DEFAULT_MODEL=claude-opus-4-7
PROXY_API_KEY=SENHA_FORTE_DO_BRIDGE
DASHBOARD_PASSWORD=SENHA_DO_PAINEL

# ── Retry ──────────────────────────────────────────────────
# true = tenta para sempre até a API voltar (recomendado para nuoda)
# false = usa UPSTREAM_RETRY_ATTEMPTS como limite
UPSTREAM_INFINITE_RETRY=true
UPSTREAM_RETRY_ATTEMPTS=5
UPSTREAM_RETRY_BASE_DELAY_MS=1000
UPSTREAM_RETRY_MAX_DELAY_MS=20000
UPSTREAM_RETRY_JITTER_MS=750

# ── Concorrência e timing ──────────────────────────────────
UPSTREAM_MAX_CONCURRENCY=1
UPSTREAM_MIN_INTERVAL_MS=1500
UPSTREAM_TIMEOUT_MS=180000

# ── Circuit breaker ────────────────────────────────────────
UPSTREAM_CIRCUIT_FAILURES=3
UPSTREAM_CIRCUIT_COOLDOWN_MS=60000

# ── OpenClaw ───────────────────────────────────────────────
OPENCLAW_FORCE_NON_STREAM_RETRY=true

# ── DNS ────────────────────────────────────────────────────
NODE_OPTIONS=--dns-result-order=ipv4first

# ── Guardrails ─────────────────────────────────────────────
GR_PII_ENABLED=true
GR_MAX_TOKENS_ENABLED=true
GR_MAX_TOKENS_LIMIT=8192
GR_BUDGET_ENABLED=true
GR_BUDGET_DAILY_USD=10
GR_MODEL_SWAP_ENABLED=true

# ── Precificação estimada (USD por milhão de tokens) ───────
# Ajuste conforme o modelo que você usa na nuoda
PRICING_INPUT_PER_MILLION=15
PRICING_OUTPUT_PER_MILLION=75

# ── Portal SaaS ───────────────────────────────────────────
# JWT para autenticação do portal (gere uma string longa e aleatória)
# Se ausente, um secret aleatório em memória será usado (tokens não sobrevivem restart)
JWT_SECRET=

# PIX (geração de QR Code para pagamento)
PIX_KEY=13996666432
PIX_NAME=MATHEUS LINS LIMA
PIX_CITY=PRAIA GRANDE

# Email do admin (notificações de novos pedidos)
ADMIN_EMAIL=matheuslinspg@gmail.com

# SMTP (para envio de notificações por email)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
